#include <stdio.h>
 
int main()
{
  	int a[100], n, i, sum = 0;
  	printf("25331A05F0\n");
  	printf("Enter array size: ");
  	scanf("%d", &n);
  	printf("Enter %d elements: ", n);
  	for (i = 0; i < n; i++)
        	scanf("%d", &a[i]);
  	for (i = 0; i < n; i++)
        	sum += a[i];
  	printf("Sum = %d\n", sum);
  	return 0;
}
